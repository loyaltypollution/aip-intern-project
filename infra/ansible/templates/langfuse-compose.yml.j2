# Langfuse v3 stack — rendered by setup_langfuse.yml
# Do not edit on the remote: re-run the playbook to change config.
# Based on https://github.com/langfuse/langfuse/blob/main/docker-compose.yml (v3.170.0).
services:
  langfuse-db:
    image: postgres:17
    restart: always
    environment:
      POSTGRES_USER: langfuse
      POSTGRES_PASSWORD: "{{ lf_db_password }}"
      POSTGRES_DB: langfuse
    volumes:
      - langfuse_db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U langfuse"]
      interval: 5s
      timeout: 5s
      retries: 30

  langfuse-clickhouse:
    image: clickhouse/clickhouse-server:25.3
    restart: always
    user: "101:101"
    environment:
      CLICKHOUSE_DB: default
      CLICKHOUSE_USER: clickhouse
      CLICKHOUSE_PASSWORD: "{{ lf_clickhouse_password }}"
    volumes:
      - langfuse_clickhouse_data:/var/lib/clickhouse
      - langfuse_clickhouse_logs:/var/log/clickhouse-server
    healthcheck:
      test: wget --no-verbose --tries=1 --spider http://localhost:8123/ping || exit 1
      interval: 5s
      timeout: 5s
      retries: 30

  langfuse-redis:
    image: redis:7
    restart: always
    command: >
      --requirepass {{ lf_redis_password }} --maxmemory-policy allkeys-lru
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "{{ lf_redis_password }}", "ping"]
      interval: 5s
      timeout: 5s
      retries: 30

  langfuse-minio:
    image: minio/minio
    restart: always
    entrypoint: sh
    command: -c 'mkdir -p /data/langfuse && minio server --address ":9000" --console-address ":9001" /data'
    environment:
      MINIO_ROOT_USER: langfuse
      MINIO_ROOT_PASSWORD: "{{ lf_minio_password }}"
    volumes:
      - langfuse_minio_data:/data
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 5s
      timeout: 5s
      retries: 30

  langfuse-worker:
    image: langfuse/langfuse-worker:3
    restart: always
    depends_on:
      langfuse-db:
        condition: service_healthy
      langfuse-clickhouse:
        condition: service_healthy
      langfuse-redis:
        condition: service_healthy
      langfuse-minio:
        condition: service_healthy
    environment: &lf_env
      DATABASE_URL: "postgresql://langfuse:{{ lf_db_password }}@langfuse-db:5432/langfuse"
      SALT: "{{ lf_salt }}"
      ENCRYPTION_KEY: "{{ lf_encryption_key }}"
      TELEMETRY_ENABLED: "false"
      CLICKHOUSE_MIGRATION_URL: "clickhouse://langfuse-clickhouse:9000"
      CLICKHOUSE_URL: "http://langfuse-clickhouse:8123"
      CLICKHOUSE_USER: clickhouse
      CLICKHOUSE_PASSWORD: "{{ lf_clickhouse_password }}"
      CLICKHOUSE_CLUSTER_ENABLED: "false"
      LANGFUSE_S3_EVENT_UPLOAD_BUCKET: langfuse
      LANGFUSE_S3_EVENT_UPLOAD_REGION: auto
      LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID: langfuse
      LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY: "{{ lf_minio_password }}"
      LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT: "http://langfuse-minio:9000"
      LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE: "true"
      LANGFUSE_S3_EVENT_UPLOAD_PREFIX: "events/"
      LANGFUSE_S3_MEDIA_UPLOAD_BUCKET: langfuse
      LANGFUSE_S3_MEDIA_UPLOAD_REGION: auto
      LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID: langfuse
      LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY: "{{ lf_minio_password }}"
      LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT: "http://langfuse-minio:9000"
      LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE: "true"
      LANGFUSE_S3_MEDIA_UPLOAD_PREFIX: "media/"
      REDIS_HOST: langfuse-redis
      REDIS_PORT: 6379
      REDIS_AUTH: "{{ lf_redis_password }}"

  langfuse-web:
    image: langfuse/langfuse:3
    restart: always
    depends_on:
      langfuse-worker:
        condition: service_started
    ports:
      - "3000:3000"
    environment:
      <<: *lf_env
      NEXTAUTH_URL: "http://{{ cpu_public_ip }}:3000"
      NEXTAUTH_SECRET: "{{ lf_nextauth_secret }}"
      LANGFUSE_DEFAULT_PROJECT_ROLE: ADMIN

      # First-boot seed — creates org, project, user, and deterministic API keys.
      # These env vars only apply against an EMPTY Postgres. Once any rows exist
      # they are silently ignored. To rotate keys, destroy the postgres volume.
      LANGFUSE_INIT_ORG_ID: aip-intern
      LANGFUSE_INIT_ORG_NAME: aip-intern
      LANGFUSE_INIT_PROJECT_ID: phase1-2
      LANGFUSE_INIT_PROJECT_NAME: phase1-2-sweeps
      LANGFUSE_INIT_PROJECT_PUBLIC_KEY: "{{ lf_public_key }}"
      LANGFUSE_INIT_PROJECT_SECRET_KEY: "{{ lf_secret_key }}"
      LANGFUSE_INIT_USER_EMAIL: "{{ lf_user_email }}"
      LANGFUSE_INIT_USER_NAME: "aip-intern"
      LANGFUSE_INIT_USER_PASSWORD: "{{ lf_user_password }}"

volumes:
  langfuse_db_data:
  langfuse_clickhouse_data:
  langfuse_clickhouse_logs:
  langfuse_minio_data:
